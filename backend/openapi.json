{
    "openapi": "3.0.0",
    "info": { "title": "Exam Generator", "version": "1.0.0" },
    "components": { "schemas": {}, "parameters": {} },
    "paths": {
        "/example/hello": {
            "get": {
                "responses": {
                    "200": {
                        "description": "Hello world",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": { "type": "string", "format": "uuid" },
                                        "message": { "type": "string" }
                                    },
                                    "required": ["id", "message"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/topics": {
            "get": {
                "responses": {
                    "200": {
                        "description": "List all topics",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "topic_id": { "type": "string", "format": "uuid" },
                                            "parent_topic_id": {
                                                "type": "string",
                                                "nullable": true,
                                                "format": "uuid"
                                            },
                                            "label": { "type": "string" }
                                        },
                                        "required": ["topic_id", "parent_topic_id", "label"]
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "label": { "type": "string", "minLength": 1 },
                                    "parent_topic_id": {
                                        "type": "string",
                                        "nullable": true,
                                        "format": "uuid"
                                    }
                                },
                                "required": ["label"]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created topic",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "topic_id": { "type": "string", "format": "uuid" },
                                        "parent_topic_id": {
                                            "type": "string",
                                            "nullable": true,
                                            "format": "uuid"
                                        },
                                        "label": { "type": "string" }
                                    },
                                    "required": ["topic_id", "parent_topic_id", "label"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/topics/generate": {
            "post": {
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": { "context": { "type": "string", "minLength": 1 } },
                                "required": ["context"]
                            }
                        }
                    }
                },
                "responses": { "204": { "description": "Topics generated and inserted" } }
            }
        },
        "/admin/topics/{id}": {
            "delete": {
                "parameters": [
                    {
                        "schema": { "type": "string", "format": "uuid" },
                        "required": true,
                        "name": "id",
                        "in": "path"
                    }
                ],
                "responses": { "204": { "description": "Topic deleted" } }
            }
        },
        "/admin/dataset": {
            "get": {
                "responses": {
                    "200": {
                        "description": "List all questions",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "question_id": { "type": "string", "format": "uuid" },
                                            "active": { "type": "boolean" },
                                            "title": { "type": "string" },
                                            "question": {
                                                "anyOf": [
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["multiple_choice"]
                                                            },
                                                            "prompt": { "type": "string" },
                                                            "answers": {
                                                                "type": "array",
                                                                "items": { "type": "string" }
                                                            }
                                                        },
                                                        "required": ["type", "prompt", "answers"]
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["open_ended"]
                                                            },
                                                            "prompt": { "type": "string" }
                                                        },
                                                        "required": ["type", "prompt"]
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["boolean"]
                                                            },
                                                            "prompt": { "type": "string" }
                                                        },
                                                        "required": ["type", "prompt"]
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["matching"]
                                                            },
                                                            "prompt": { "type": "string" },
                                                            "left": {
                                                                "type": "array",
                                                                "items": { "type": "string" }
                                                            },
                                                            "right": {
                                                                "type": "array",
                                                                "items": { "type": "string" }
                                                            }
                                                        },
                                                        "required": [
                                                            "type",
                                                            "prompt",
                                                            "left",
                                                            "right"
                                                        ]
                                                    }
                                                ]
                                            },
                                            "answer": {
                                                "anyOf": [
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["multiple_choice"]
                                                            },
                                                            "selected_index": {
                                                                "type": "array",
                                                                "items": { "type": "number" }
                                                            },
                                                            "explanation": {
                                                                "type": "string",
                                                                "nullable": true
                                                            }
                                                        },
                                                        "required": [
                                                            "type",
                                                            "selected_index",
                                                            "explanation"
                                                        ]
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["open_ended"]
                                                            },
                                                            "answer": { "type": "string" },
                                                            "explanation": {
                                                                "type": "string",
                                                                "nullable": true
                                                            }
                                                        },
                                                        "required": [
                                                            "type",
                                                            "answer",
                                                            "explanation"
                                                        ]
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["boolean"]
                                                            },
                                                            "answer": { "type": "boolean" },
                                                            "explanation": {
                                                                "type": "string",
                                                                "nullable": true
                                                            }
                                                        },
                                                        "required": [
                                                            "type",
                                                            "answer",
                                                            "explanation"
                                                        ]
                                                    },
                                                    {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": ["matching"]
                                                            },
                                                            "pairs": {
                                                                "type": "array",
                                                                "items": {
                                                                    "type": "object",
                                                                    "properties": {
                                                                        "left_index": {
                                                                            "type": "number"
                                                                        },
                                                                        "right_index": {
                                                                            "type": "number"
                                                                        }
                                                                    },
                                                                    "required": [
                                                                        "left_index",
                                                                        "right_index"
                                                                    ]
                                                                }
                                                            },
                                                            "explanation": {
                                                                "type": "string",
                                                                "nullable": true
                                                            }
                                                        },
                                                        "required": ["type", "pairs", "explanation"]
                                                    }
                                                ]
                                            },
                                            "topic_ids": {
                                                "type": "array",
                                                "items": { "type": "string", "format": "uuid" }
                                            }
                                        },
                                        "required": [
                                            "question_id",
                                            "active",
                                            "title",
                                            "question",
                                            "answer",
                                            "topic_ids"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/dataset/generate": {
            "post": {
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": { "prompt": { "type": "string", "minLength": 1 } },
                                "required": ["prompt"]
                            }
                        }
                    }
                },
                "responses": {
                    "202": {
                        "description": "Generation job accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "job_id": { "type": "string", "format": "uuid" }
                                    },
                                    "required": ["job_id"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/dataset/jobs": {
            "get": {
                "responses": {
                    "200": {
                        "description": "List all generation jobs",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "job_id": { "type": "string", "format": "uuid" },
                                            "status": {
                                                "type": "string",
                                                "enum": ["running", "done", "error"]
                                            },
                                            "prompt": { "type": "string" },
                                            "created_at": { "type": "string" },
                                            "total": { "type": "number" },
                                            "completed": { "type": "number" },
                                            "error": { "type": "string" }
                                        },
                                        "required": [
                                            "job_id",
                                            "status",
                                            "prompt",
                                            "created_at",
                                            "total",
                                            "completed"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/signup": {
            "post": {
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": { "username": { "type": "string", "minLength": 1 } },
                                "required": ["username"]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Student created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "student_id": { "type": "string", "format": "uuid" }
                                    },
                                    "required": ["student_id"]
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Username already taken",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": { "username": { "type": "string", "minLength": 1 } },
                                "required": ["username"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Logged in",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "student_id": { "type": "string", "format": "uuid" }
                                    },
                                    "required": ["student_id"]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Student not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": { "error": { "type": "string" } },
                                    "required": ["error"]
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
