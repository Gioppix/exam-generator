{
    "name": "backend",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "build": "tsc",
        "start": "node --env-file=.env dist/index.js",
        "start:prod": "node dist/index.js",
        "format": "prettier --write .",
        "gen:api": "tsx --env-file=.env scripts/gen-openapi.ts",
        "db:dev": "source .env && psql $DATABASE_URL -c \"DROP SCHEMA public CASCADE\" && psql $DATABASE_URL -c \"CREATE SCHEMA public\" && psql $DATABASE_URL -f migrations.sql"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.58",
        "@ai-sdk/openai": "^3.0.41",
        "@hono/node-server": "^1.19.11",
        "@hono/zod-openapi": "^1.2.2",
        "ai": "^6.0.116",
        "hono": "^4.12.7",
        "pg": "^8.13.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.13.10",
        "@types/pg": "^8.11.11",
        "prettier": "3.8.1",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}
